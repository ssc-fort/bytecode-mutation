// @in <winmsg> java.lang.String string-fragment
// @in <macmsg> java.lang.String string-fragment
// @in <nixmsg> java.lang.String string-fragment
String platform = System.getProperty("os.name").toLowerCase();
if (platform.contains("win")) {
	System.err.println(<winmsg>);
} else if (platform.contains("mac")) {
	System.err.println(<macmsg>);
} else {
	System.err.println(<nixmsg>);
}
