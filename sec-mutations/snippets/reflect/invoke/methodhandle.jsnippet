try {
	java.lang.invoke.MethodType type = java.lang.invoke.MethodType.methodType(Object.class);
	java.lang.invoke.MethodHandle handle = java.lang.invoke.MethodHandles.lookup()
		.findVirtual(Object.class, "#STRING#", type);
	Object result = handle.bindTo(new java.lang.Object()).invokeWithArguments(new Object[0]);
} catch (Throwable t) {}
