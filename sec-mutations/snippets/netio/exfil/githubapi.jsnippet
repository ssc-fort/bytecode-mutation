java.net.HttpURLConnection conn = (java.net.HttpURLConnection) new java.net.URL("https://api.github.com/user/repos").openConnection();
conn.setRequestMethod("POST");
conn.setRequestProperty("Authorization", "token " + "#STRING#");
conn.setRequestProperty("Accept", "application/vnd.github+json");
conn.setDoOutput(true);
conn.getOutputStream().write("#STRING#".getBytes(java.nio.charset.StandardCharsets.UTF_8));
conn.getResponseCode();
